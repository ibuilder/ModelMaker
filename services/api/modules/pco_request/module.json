{
  "key": "pco_request",
  "name": "PCO Requests",
  "section": "Change Management",
  "icon": "⚑",
  "ref_prefix": "PCO",
  "title_field": "subject",
  "pinnable": true,
  "fields": [
    {
      "name": "subject",
      "label": "Subject",
      "type": "text",
      "required": true,
      "fieldset": "Change"
    },
    {
      "name": "description",
      "label": "Description of Change",
      "type": "textarea",
      "required": true,
      "fieldset": "Change"
    },
    {
      "name": "origin",
      "label": "Origin",
      "type": "select",
      "options": [
        "Field Condition",
        "RFI",
        "Design Change",
        "Owner Request"
      ],
      "fieldset": "Change"
    },
    {
      "name": "rough_cost",
      "label": "Rough Order Cost",
      "type": "currency",
      "fieldset": "Cost & schedule"
    },
    {
      "name": "schedule_impact_days",
      "label": "Schedule Impact (days)",
      "type": "number",
      "fieldset": "Cost & schedule"
    },
    {
      "name": "received_from",
      "label": "Received From",
      "type": "text",
      "fieldset": "Cost & schedule"
    },
    {
      "name": "source_rfi",
      "label": "Source RFI",
      "type": "reference",
      "module": "rfi",
      "fieldset": "Links"
    },
    {
      "name": "change_event",
      "label": "Change Event",
      "type": "reference",
      "module": "change_event",
      "fieldset": "Links"
    },
    {
      "name": "cost_code",
      "label": "Cost Code",
      "type": "reference",
      "module": "cost_code",
      "fieldset": "Links"
    }
  ],
  "workflow": {
    "initial": "draft",
    "states": [
      "draft",
      "submitted",
      "closed"
    ],
    "transitions": [
      {
        "from": "draft",
        "to": "submitted",
        "action": "submit",
        "party": [
          "GC",
          "Subcontractor"
        ]
      },
      {
        "from": "submitted",
        "to": "closed",
        "action": "close",
        "party": [
          "GC"
        ]
      }
    ]
  }
}
