    { "name": "email", "label": "Email", "type": "text" },
    { "name": "phone", "label": "Phone", "type": "text" },
    { "name": "discipline", "label": "Discipline", "type": "text" },
    { "name": "notes", "label": "Notes", "type": "textarea" }
