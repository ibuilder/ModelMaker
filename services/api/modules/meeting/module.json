{
  "key": "meeting",
  "name": "Meetings",
  "section": "Engineering",
  "icon": "☷",
  "ref_prefix": "MTG",
  "title_field": "subject",
  "pinnable": false,
  "fields": [
    {
      "name": "subject",
      "label": "Meeting",
      "type": "text",
      "required": true
    },
    {
      "name": "date",
      "label": "Date",
      "type": "date"
    },
    {
      "name": "minutes",
      "label": "Minutes",
      "type": "textarea"
    },
    {
      "name": "location",
      "label": "Location",
      "type": "text"
    },
    {
      "name": "meeting_type",
      "label": "Type",
      "type": "select",
      "options": [
        "OAC",
        "Coordination",
        "Safety",
        "Preconstruction",
        "Progress"
      ]
    },
    {
      "name": "action_count",
      "label": "# action items",
      "type": "rollup",
      "source_module": "action_item",
      "source_field": "subject",
      "op": "count"
    }
  ],
  "workflow": {
    "initial": "agenda",
    "states": [
      "agenda",
      "minutes"
    ],
    "transitions": [
      {
        "from": "agenda",
        "to": "minutes",
        "action": "publish_minutes",
        "party": [
          "GC"
        ]
      }
    ]
  },
  "list_columns": [
    "meeting_type",
    "date"
  ]
}
